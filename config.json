<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Analytics">
<title>Indie Analytics</title>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
body { font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', system-ui, sans-serif; background: #0a0a0a; color: #e5e5e5; padding: 16px; padding-top: env(safe-area-inset-top, 16px); padding-bottom: calc(env(safe-area-inset-bottom, 0px) + 16px); min-height: 100vh; overflow-x: hidden; }
h1 { font-size: 22px; font-weight: 600; margin-bottom: 16px; color: #C8A45C; }
.header-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
.last-updated { font-size: 10px; color: #444; }
.grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; margin-bottom: 10px; }
.card { background: #1a1a1a; border-radius: 14px; padding: 14px; }
.card-label { font-size: 11px; color: #888; margin-bottom: 4px; text-transform: uppercase; letter-spacing: 0.5px; }
.card-value { font-size: 26px; font-weight: 600; }
.card-sub { font-size: 11px; color: #555; margin-top: 3px; }
.gold { color: #C8A45C; }
.green { color: #4ade80; }
.blue { color: #60a5fa; }
.purple { color: #a78bfa; }
.teal { color: #2dd4bf; }
.growth-up { color: #4ade80; font-size: 11px; font-weight: 600; }
.growth-down { color: #f87171; font-size: 11px; font-weight: 600; }
.growth-flat { color: #888; font-size: 11px; }
.section { background: #1a1a1a; border-radius: 14px; padding: 14px; margin-bottom: 12px; }
.section-title { font-size: 13px; font-weight: 600; color: #888; margin-bottom: 10px; display: flex; justify-content: space-between; align-items: center; text-transform: uppercase; letter-spacing: 0.5px; }
table { width: 100%; border-collapse: collapse; }
th { text-align: left; font-size: 10px; color: #555; padding: 6px 0; border-bottom: 1px solid #222; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
td { font-size: 13px; padding: 10px 0; border-bottom: 1px solid #151515; }
.badge { display: inline-block; font-size: 9px; padding: 3px 8px; border-radius: 6px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.3px; }
.badge-iap { background: #0a2a0a; color: #4ade80; }
.badge-offer { background: #2a1a0a; color: #C8A45C; }
.badge-dl { background: #0a1a2a; color: #60a5fa; }
.login-wrap { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 80vh; gap: 16px; }
.login-wrap input { background: #1a1a1a; border: 1px solid #333; border-radius: 12px; padding: 14px 16px; color: #e5e5e5; font-size: 14px; width: 100%; max-width: 300px; text-align: center; }
.login-wrap button { background: #C8A45C; color: #0a0a0a; border: none; border-radius: 12px; padding: 14px 32px; font-size: 15px; font-weight: 600; cursor: pointer; width: 100%; max-width: 300px; }
.app-tabs { display: flex; gap: 6px; margin-bottom: 12px; }
.app-tab { padding: 7px 16px; border-radius: 10px; font-size: 13px; font-weight: 600; cursor: pointer; background: #1a1a1a; color: #666; border: none; }
.app-tab.active { background: #C8A45C; color: #0a0a0a; }
.time-tabs { display: flex; gap: 4px; margin-bottom: 16px; }
.time-tab { padding: 6px 12px; border-radius: 8px; font-size: 11px; font-weight: 500; cursor: pointer; background: #111; color: #666; border: none; }
.time-tab.active { background: #222; color: #e5e5e5; }
.error { color: #f87171; font-size: 13px; margin-top: 8px; }
.btn-sm { background: none; border: 1px solid #222; color: #666; padding: 8px 16px; border-radius: 10px; cursor: pointer; font-size: 12px; font-weight: 500; }
.btn-sm.loading { opacity: 0.4; pointer-events: none; }
.btn-del { background: none; border: none; color: #333; cursor: pointer; font-size: 16px; padding: 4px 8px; }
.btn-del:hover { color: #f87171; }
.btn-danger { background: none; border: 1px solid #7f1d1d; color: #f87171; padding: 6px 12px; border-radius: 8px; cursor: pointer; font-size: 11px; font-weight: 500; }
.btn-cancel { background: none; border: 1px solid #333; color: #888; padding: 4px 8px; border-radius: 6px; cursor: pointer; font-size: 10px; }
.btn-confirm-del { background: #7f1d1d; border: none; color: #fecaca; padding: 4px 8px; border-radius: 6px; cursor: pointer; font-size: 10px; font-weight: 600; }
.inline-confirm { display: flex; gap: 4px; align-items: center; }
.clear-confirm { display: inline-flex; gap: 6px; align-items: center; }
.bar-row { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
.bar-label { font-size: 11px; color: #666; width: 32px; text-align: right; }
.bar-track { flex: 1; height: 6px; background: #111; border-radius: 3px; overflow: hidden; }
.bar-fill { height: 100%; border-radius: 3px; transition: width 0.3s; }
.bar-value { font-size: 11px; color: #888; width: 28px; }
.chart-section { margin-bottom: 12px; }
.chart-bars { display: flex; align-items: flex-end; gap: 2px; height: 80px; padding-top: 4px; }
.chart-bar-wrap { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 2px; height: 100%; justify-content: flex-end; min-width: 0; }
.chart-bar { width: 100%; min-height: 2px; border-radius: 3px 3px 0 0; transition: height 0.3s; }
.chart-label { font-size: 7px; color: #444; white-space: nowrap; overflow: hidden; }
.empty { text-align: center; padding: 24px; color: #333; font-size: 13px; }
.live-dot { display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: #4ade80; margin-right: 6px; animation: pulse 2s infinite; }
@keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }
.footer { text-align: center; padding: 20px 0; display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; }
.footer-info { width: 100%; font-size: 10px; color: #333; margin-top: 4px; }
.stat-row { display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid #151515; }
.stat-row:last-child { border-bottom: none; }
.toast { position: fixed; top: 20px; left: 50%; transform: translateX(-50%); padding: 12px 20px; border-radius: 12px; font-size: 14px; font-weight: 600; z-index: 9999; animation: slideDown 0.3s ease, fadeOut 0.5s ease 2.5s; pointer-events: none; white-space: nowrap; }
.toast-dl { background: #0a1a2a; color: #60a5fa; border: 1px solid #1a3a5a; }
.toast-iap { background: #0a2a0a; color: #4ade80; border: 1px solid #1a4a1a; }
@keyframes slideDown { from { top: -50px; opacity: 0; } to { top: 20px; opacity: 1; } }
@keyframes fadeOut { to { opacity: 0; } }
.confetti { position: fixed; top: -10px; width: 8px; height: 8px; z-index: 9998; pointer-events: none; border-radius: 2px; }
@keyframes confettiFall { 0% { transform: translateY(0) rotate(0deg); opacity: 1; } 100% { transform: translateY(100vh) rotate(720deg); opacity: 0; } }
</style>
</head>
<body>

<div id="loginView" class="login-wrap">
  <h1>Indie Analytics</h1>
  <input type="password" id="keyInput" placeholder="Enter service_role key" />
  <button onclick="login()">Unlock</button>
  <div id="loginError" class="error"></div>
</div>

<div id="dashboard" style="display:none;">
  <div class="header-row">
    <h1 style="margin:0;"><span class="live-dot"></span>Indie Analytics</h1>
    <span class="last-updated" id="lastUpdated"></span>
  </div>

  <div class="app-tabs">
    <button class="app-tab active" onclick="filterApp('all', this)">All</button>
    <button class="app-tab" onclick="filterApp('personalcapsule', this)">PC</button>
    <button class="app-tab" onclick="filterApp('yula', this)">Yula</button>
  </div>

  <div class="time-tabs">
    <button class="time-tab" onclick="filterTime('today', this)">Today</button>
    <button class="time-tab" onclick="filterTime('7d', this)">7d</button>
    <button class="time-tab" onclick="filterTime('30d', this)">30d</button>
    <button class="time-tab active" onclick="filterTime('lifetime', this)">Lifetime</button>
  </div>

  <!-- Row 1: Downloads | Purchases -->
  <div class="grid">
    <div class="card">
      <div class="card-label">Downloads</div>
      <div class="card-value blue" id="totalDownloads">-</div>
      <div class="card-sub" id="dlSub"></div>
    </div>
    <div class="card">
      <div class="card-label">Purchases</div>
      <div class="card-value green" id="totalPurchases">-</div>
      <div class="card-sub" id="prSub"></div>
    </div>
  </div>

  <!-- Row 2: Revenue | Proceeds -->
  <div class="grid">
    <div class="card">
      <div class="card-label">Revenue</div>
      <div class="card-value gold" id="totalRevenue">-</div>
      <div class="card-sub" id="revSub"></div>
    </div>
    <div class="card">
      <div class="card-label">Proceeds</div>
      <div class="card-value teal" id="totalProceeds">-</div>
      <div class="card-sub">after Apple 15%</div>
    </div>
  </div>

  <!-- Row 3: Conversion | ARPU -->
  <div class="grid" style="margin-bottom:20px;">
    <div class="card">
      <div class="card-label">Conversion</div>
      <div class="card-value purple" id="conversionRate">-</div>
      <div class="card-sub">purchase / download</div>
    </div>
    <div class="card">
      <div class="card-label">ARPU</div>
      <div class="card-value gold" id="arpu">-</div>
      <div class="card-sub">revenue / download</div>
    </div>
  </div>

  <div class="section" id="goalSection">
    <div class="section-title">
      <span id="goalMonth">Monthly Goal</span>
      <button class="btn-sm" onclick="editGoal()" id="goalEditBtn" style="font-size:10px;padding:4px 10px;">Edit</button>
    </div>
    <div id="goalContent"></div>
    <div id="goalEditor" style="display:none;">
      <div style="display:flex;gap:8px;align-items:center;">
        <span style="font-size:14px;color:#888;">$</span>
        <input type="number" id="goalInput" style="background:#111;border:1px solid #333;border-radius:8px;padding:8px 12px;color:#e5e5e5;font-size:16px;width:100px;text-align:center;" />
        <button class="btn-sm" onclick="saveGoal()" style="background:#C8A45C;color:#0a0a0a;border:none;font-weight:600;">Save</button>
        <button class="btn-sm" onclick="cancelGoalEdit()">Cancel</button>
      </div>
    </div>
  </div>

  <div class="section chart-section">
    <div class="section-title"><span id="chartTitle">Activity</span></div>
    <div class="chart-bars" id="dynamicChart"></div>
  </div>

  <div class="section">
    <div class="section-title"><span>Revenue by currency</span></div>
    <div id="revenueByCurrency"></div>
  </div>

  <div class="section">
    <div class="section-title"><span>Source breakdown</span></div>
    <div id="sourceBreakdown"></div>
  </div>

  <div class="section">
    <div class="section-title"><span>Top countries</span></div>
    <div id="countryBars"></div>
  </div>

  <div class="section">
    <div class="section-title"><span>Devices</span></div>
    <div id="deviceBars"></div>
  </div>

  <div class="section">
    <div class="section-title">
      <span>Recent events</span>
      <span id="clearAllBtn"><button class="btn-danger" onclick="askClearAll()">Clear all</button></span>
    </div>
    <table>
      <thead><tr><th>Time</th><th>Event</th><th>Detail</th><th></th></tr></thead>
      <tbody id="eventsTable"></tbody>
    </table>
    <div id="emptyState" class="empty" style="display:none;">No events yet</div>
  </div>

  <div class="footer">
    <button class="btn-sm" id="refreshBtn" onclick="manualRefresh()">Refresh</button>
    <button class="btn-sm" onclick="exportData()">Export</button>
    <button class="btn-sm" onclick="logout()">Logout</button>
    <div class="footer-info" id="rateInfo"></div>
  </div>
</div>

<script>
var SUPABASE_URL = 'https://vpsmaqsessodayyjamnd.supabase.co';
var SECRET_KEY = '';
var allEvents = [];
var currentApp = 'all';
var currentTime = 'lifetime';
var prevDownloads = -1;
var prevRevenue = -1;
var fxRates = {};

function confetti() {
  var colors = ['#C8A45C','#4ade80','#60a5fa','#a78bfa','#f87171','#fbbf24','#e879f9'];
  for (var i = 0; i < 40; i++) {
    var el = document.createElement('div');
    el.className = 'confetti';
    el.style.left = Math.random() * 100 + 'vw';
    el.style.background = colors[Math.floor(Math.random() * colors.length)];
    el.style.width = (4 + Math.random() * 6) + 'px';
    el.style.height = (4 + Math.random() * 6) + 'px';
    el.style.animation = 'confettiFall ' + (1.5 + Math.random() * 2) + 's ease forwards';
    el.style.animationDelay = Math.random() * 0.5 + 's';
    document.body.appendChild(el);
    setTimeout(function(e) { e.remove(); }.bind(null, el), 4000);
  }
}

function fireworks() {
  var colors = ['#C8A45C','#4ade80','#60a5fa','#f87171','#fbbf24','#e879f9','#ffffff'];
  for (var burst = 0; burst < 3; burst++) {
    var cx = 20 + Math.random() * 60;
    var cy = 15 + Math.random() * 30;
    var delay = burst * 400;
    for (var i = 0; i < 20; i++) {
      var color = colors[Math.floor(Math.random() * colors.length)];
      var el = document.createElement('div');
      el.style.cssText = 'position:fixed;width:4px;height:4px;border-radius:50%;z-index:9998;pointer-events:none;opacity:1;';
      el.style.left = cx + 'vw';
      el.style.top = cy + 'vh';
      el.style.background = color;
      el.style.boxShadow = '0 0 6px ' + color;
      var angle = (Math.PI * 2 / 20) * i;
      var dist = 80 + Math.random() * 120;
      var dx = Math.cos(angle) * dist;
      var dy = Math.sin(angle) * dist;
      el.style.transition = 'all ' + (0.6 + Math.random() * 0.4) + 's cubic-bezier(0,.8,.5,1)';
      document.body.appendChild(el);
      (function(el, dx, dy, delay) {
        setTimeout(function() {
          el.style.transform = 'translate(' + dx + 'px,' + dy + 'px) scale(0)';
          el.style.opacity = '0';
        }, delay + 50);
        setTimeout(function() { el.remove(); }, delay + 1500);
      })(el, dx, dy, delay);
    }
  }
}

function showToast(msg, type) {
  var el = document.createElement('div');
  el.className = 'toast toast-' + type;
  el.textContent = msg;
  document.body.appendChild(el);
  setTimeout(function() { el.remove(); }, 3000);
}

function toUSD(price, currency) {
  if (!price) return 0;
  var amount = parseFloat(price);
  if (!currency || currency === 'USD') return amount;
  var rate = fxRates[currency];
  if (!rate) return amount;
  return amount / rate;
}

function loadFxRates() {
  return fetch('https://api.frankfurter.dev/v1/latest?base=USD')
    .then(function(r) { return r.json(); })
    .then(function(data) {
      fxRates = data.rates || {};
      var d = document.getElementById('rateInfo');
      if (d) d.textContent = 'FX rates: ' + data.date;
    })
    .catch(function() {
      fxRates = { EUR: 0.92, GBP: 0.79, TRY: 38.5, BRL: 5.6, MXN: 19.5, INR: 85, IDR: 16200, CAD: 1.37, AUD: 1.55, JPY: 155 };
    });
}

function login() {
  SECRET_KEY = document.getElementById('keyInput').value.trim();
  if (!SECRET_KEY) return;
  document.getElementById('loginError').textContent = '';
  loadFxRates().then(function() { return loadData(); }).then(function(ok) {
    if (ok) {
      localStorage.setItem('sb_key_v5', SECRET_KEY);
      document.getElementById('loginView').style.display = 'none';
      document.getElementById('dashboard').style.display = 'block';
    }
  });
}

function logout() {
  localStorage.removeItem('sb_key_v5');
  SECRET_KEY = '';
  allEvents = [];
  prevDownloads = -1;
  prevRevenue = -1;
  document.getElementById('dashboard').style.display = 'none';
  document.getElementById('loginView').style.display = 'flex';
  document.getElementById('keyInput').value = '';
}

function init() {
  var saved = localStorage.getItem('sb_key_v5');
  if (saved) {
    SECRET_KEY = saved;
    loadFxRates().then(function() { return loadData(); }).then(function(ok) {
      if (ok) {
        document.getElementById('loginView').style.display = 'none';
        document.getElementById('dashboard').style.display = 'block';
      } else { localStorage.removeItem('sb_key_v5'); }
    });
  }
}

function manualRefresh() {
  var btn = document.getElementById('refreshBtn');
  btn.classList.add('loading');
  btn.textContent = '...';
  loadData().then(function() {
    btn.classList.remove('loading');
    btn.textContent = 'Refresh';
  });
}

function loadData() {
  return fetch(SUPABASE_URL + '/rest/v1/events?select=*&order=created_at.desc&limit=10000', {
    headers: { 'apikey': SECRET_KEY, 'Authorization': 'Bearer ' + SECRET_KEY }
  }).then(function(res) {
    if (!res.ok) {
      document.getElementById('loginError').textContent = 'Invalid key (HTTP ' + res.status + ')';
      return false;
    }
    return res.json().then(function(data) {
      allEvents = data;
      var now = new Date();
      document.getElementById('lastUpdated').textContent = now.toLocaleTimeString('tr-TR', { hour: '2-digit', minute: '2-digit' });
      checkForNew();
      render();
      return true;
    });
  }).catch(function(e) {
    document.getElementById('loginError').textContent = 'Connection error';
    return false;
  });
}

function checkForNew() {
  var downloads = allEvents.filter(function(e) { return e.event === 'download'; }).length;
  var revenue = 0;
  allEvents.filter(function(e) { return e.event === 'purchase' && e.source !== 'offerCode'; }).forEach(function(e) {
    revenue += toUSD(e.price, e.currency);
  });
  if (prevDownloads >= 0 && downloads > prevDownloads) {
    var n = downloads - prevDownloads;
    showToast('+ ' + n + ' new download' + (n > 1 ? 's' : '') + '!', 'dl');
    confetti();
  }
  if (prevRevenue >= 0 && revenue > prevRevenue) {
    showToast('+ $' + (revenue - prevRevenue).toFixed(2) + ' revenue!', 'iap');
    fireworks();
    confetti();
  }
  prevDownloads = downloads;
  prevRevenue = revenue;
}

function filterApp(app, btn) {
  currentApp = app;
  var tabs = document.querySelectorAll('.app-tab');
  for (var i = 0; i < tabs.length; i++) tabs[i].classList.remove('active');
  btn.classList.add('active');
  render();
}

function showDeleteConfirm(id) {
  var cell = document.getElementById('del-' + id);
  if (!cell) return;
  cell.innerHTML = '<div class="inline-confirm">'
    + '<button class="btn-cancel" onclick="render()">No</button>'
    + '<button class="btn-confirm-del" onclick="doDelete(' + id + ')">Yes</button></div>';
}

function doDelete(id) {
  fetch(SUPABASE_URL + '/rest/v1/events?id=eq.' + id, {
    method: 'DELETE',
    headers: { 'apikey': SECRET_KEY, 'Authorization': 'Bearer ' + SECRET_KEY }
  }).then(function(res) { if (res.ok) loadData(); });
}

function askClearAll() {
  var events = getFiltered();
  if (events.length === 0) return;
  document.getElementById('clearAllBtn').innerHTML = '<span class="clear-confirm">'
    + '<span style="font-size:11px;color:#f87171;">' + events.length + '?</span>'
    + '<button class="btn-cancel" onclick="cancelClearAll()">No</button>'
    + '<button class="btn-confirm-del" onclick="doClearAll()">Yes</button></span>';
}

function cancelClearAll() {
  document.getElementById('clearAllBtn').innerHTML = '<button class="btn-danger" onclick="askClearAll()">Clear all</button>';
}

function doClearAll() {
  var ids = getFiltered().map(function(e) { return e.id; });
  if (ids.length === 0) return;
  fetch(SUPABASE_URL + '/rest/v1/events?id=in.(' + ids.join(',') + ')', {
    method: 'DELETE',
    headers: { 'apikey': SECRET_KEY, 'Authorization': 'Bearer ' + SECRET_KEY }
  }).then(function(res) { if (res.ok) { cancelClearAll(); loadData(); } });
}

function filterTime(t, btn) {
  currentTime = t;
  var tabs = document.querySelectorAll('.time-tab');
  for (var i = 0; i < tabs.length; i++) tabs[i].classList.remove('active');
  btn.classList.add('active');
  render();
}

function getFiltered() {
  var events = currentApp === 'all' ? allEvents : allEvents.filter(function(e) { return e.app === currentApp; });
  if (currentTime === 'lifetime') return events;
  var now = new Date();
  var cutoff;
  if (currentTime === 'today') cutoff = new Date(now.getFullYear(), now.getMonth(), now.getDate());
  else if (currentTime === '7d') cutoff = new Date(now - 7 * 86400000);
  else if (currentTime === '30d') cutoff = new Date(now - 30 * 86400000);
  return events.filter(function(e) { return new Date(e.created_at) >= cutoff; });
}

function getYesterday() {
  var now = new Date();
  var yStart = new Date(now.getFullYear(), now.getMonth(), now.getDate() - 1);
  var yEnd = new Date(now.getFullYear(), now.getMonth(), now.getDate());
  var appEvents = currentApp === 'all' ? allEvents : allEvents.filter(function(e) { return e.app === currentApp; });
  return appEvents.filter(function(e) {
    var d = new Date(e.created_at);
    return d >= yStart && d < yEnd;
  });
}

function growthBadge(today, yesterday, suffix) {
  if (yesterday === 0 && today === 0) return '<span class="growth-flat">—</span>';
  if (yesterday === 0) return '<span class="growth-up">new</span>';
  var pct = Math.round(((today - yesterday) / yesterday) * 100);
  if (pct > 0) return '<span class="growth-up">↑' + pct + '%' + (suffix || '') + '</span>';
  if (pct < 0) return '<span class="growth-down">↓' + Math.abs(pct) + '%' + (suffix || '') + '</span>';
  return '<span class="growth-flat">→ 0%</span>';
}

function makeBar(label, value, max, color) {
  var pct = max > 0 ? Math.round((value / max) * 100) : 0;
  return '<div class="bar-row">'
    + '<div class="bar-label">' + label + '</div>'
    + '<div class="bar-track"><div class="bar-fill" style="width:' + pct + '%;background:' + color + '"></div></div>'
    + '<div class="bar-value">' + value + '</div></div>';
}

function makeWideBar(label, value, max, color) {
  var pct = max > 0 ? Math.round((value / max) * 100) : 0;
  return '<div class="bar-row">'
    + '<div style="font-size:11px;color:#666;width:72px;text-align:right;flex-shrink:0;">' + label + '</div>'
    + '<div class="bar-track"><div class="bar-fill" style="width:' + pct + '%;background:' + color + '"></div></div>'
    + '<div class="bar-value">' + value + '</div></div>';
}

function buildChart(events) {
  var today = new Date().toISOString().slice(0, 10);
  var buckets = [];
  var labels = [];
  var title = '';

  if (currentTime === 'today') {
    title = 'Today by hour';
    for (var h = 0; h < 24; h++) {
      var hh = h.toString().padStart(2, '0');
      buckets.push(events.filter(function(e) {
        return e.created_at && e.created_at.startsWith(today + 'T' + hh);
      }).length);
      labels.push(h % 6 === 0 ? hh + ':00' : '');
    }
  } else if (currentTime === '7d') {
    title = 'Last 7 days';
    var dayNames = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
    for (var i = 6; i >= 0; i--) {
      var d = new Date(Date.now() - i * 86400000);
      var ds = d.toISOString().slice(0, 10);
      buckets.push(events.filter(function(e) { return e.created_at && e.created_at.startsWith(ds); }).length);
      labels.push(dayNames[d.getDay()]);
    }
  } else if (currentTime === '30d') {
    title = 'Last 30 days';
    for (var i = 29; i >= 0; i--) {
      var d = new Date(Date.now() - i * 86400000);
      var ds = d.toISOString().slice(0, 10);
      buckets.push(events.filter(function(e) { return e.created_at && e.created_at.startsWith(ds); }).length);
      labels.push(i % 7 === 0 ? d.getDate() + '/' + (d.getMonth() + 1) : '');
    }
  } else {
    title = 'All time (weekly)';
    if (events.length === 0) return { title: title, html: '<div class="empty">No data yet</div>' };
    var sorted = events.slice().sort(function(a, b) { return new Date(a.created_at) - new Date(b.created_at); });
    var first = new Date(sorted[0].created_at);
    var now = new Date();
    var weeks = Math.ceil((now - first) / (7 * 86400000)) || 1;
    if (weeks > 52) weeks = 52;
    for (var w = weeks - 1; w >= 0; w--) {
      var wStart = new Date(now - (w + 1) * 7 * 86400000);
      var wEnd = new Date(now - w * 7 * 86400000);
      buckets.push(events.filter(function(e) {
        var d = new Date(e.created_at);
        return d >= wStart && d < wEnd;
      }).length);
      var label = (wStart.getDate()) + '/' + (wStart.getMonth() + 1);
      labels.push(weeks <= 12 ? label : (w % 4 === 0 ? label : ''));
    }
  }

  var max = Math.max.apply(null, buckets) || 1;
  var html = buckets.map(function(count, idx) {
    var h = Math.max(2, Math.round((count / max) * 70));
    var isLast = idx === buckets.length - 1;
    var color = isLast ? '#C8A45C' : '#60a5fa';
    return '<div class="chart-bar-wrap">'
      + '<div style="font-size:8px;color:#888;">' + (count > 0 ? count : '') + '</div>'
      + '<div class="chart-bar" style="height:' + h + 'px;background:' + color + '"></div>'
      + '<div class="chart-label">' + labels[idx] + '</div></div>';
  }).join('');

  return { title: title, html: html };
}

function render() {
  var events = getFiltered();
  var today = new Date().toISOString().slice(0, 10);

  var downloads = events.filter(function(e) { return e.event === 'download'; });
  var purchases = events.filter(function(e) { return e.event === 'purchase'; });
  var paidPurchases = purchases.filter(function(e) { return e.source !== 'offerCode'; });
  var offerPurchases = purchases.filter(function(e) { return e.source === 'offerCode'; });

  var revenueUSD = 0;
  paidPurchases.forEach(function(e) { revenueUSD += toUSD(e.price, e.currency); });
  var proceedsUSD = revenueUSD * 0.85;
  var arpuVal = downloads.length > 0 ? (revenueUSD / downloads.length) : 0;
  var convRate = downloads.length > 0 ? ((purchases.length / downloads.length) * 100).toFixed(1) : '0';

  // Growth (today only)
  var dlGrowth = '', prGrowth = '', revGrowth = '';
  if (currentTime === 'today') {
    var yEvents = getYesterday();
    var yDL = yEvents.filter(function(e) { return e.event === 'download'; }).length;
    var yPR = yEvents.filter(function(e) { return e.event === 'purchase'; }).length;
    var yRev = 0;
    yEvents.filter(function(e) { return e.event === 'purchase' && e.source !== 'offerCode'; }).forEach(function(e) { yRev += toUSD(e.price, e.currency); });
    dlGrowth = ' ' + growthBadge(downloads.length, yDL, ' vs yesterday');
    prGrowth = ' ' + growthBadge(purchases.length, yPR, ' vs yesterday');
    revGrowth = ' ' + growthBadge(Math.round(revenueUSD), Math.round(yRev), ' vs yesterday');
  }

  document.getElementById('totalDownloads').textContent = downloads.length;
  document.getElementById('dlSub').innerHTML = offerPurchases.length + ' codes / ' + paidPurchases.length + ' paid' + dlGrowth;
  document.getElementById('totalPurchases').textContent = purchases.length;
  document.getElementById('prSub').innerHTML = (currentTime === 'today' ? purchases.length + ' today' : downloads.length + ' users') + prGrowth;
  document.getElementById('totalRevenue').textContent = '$' + revenueUSD.toFixed(2);
  document.getElementById('revSub').innerHTML = 'gross' + revGrowth;
  document.getElementById('totalProceeds').textContent = '$' + proceedsUSD.toFixed(2);
  document.getElementById('conversionRate').textContent = convRate + '%';
  document.getElementById('arpu').textContent = '$' + arpuVal.toFixed(2);

  renderGoal();

  var chart = buildChart(events);
  document.getElementById('chartTitle').textContent = chart.title;
  document.getElementById('dynamicChart').innerHTML = chart.html;

  var byCurrency = {};
  paidPurchases.forEach(function(e) {
    var c = e.currency || 'USD';
    if (!byCurrency[c]) byCurrency[c] = { total: 0, count: 0 };
    byCurrency[c].total += parseFloat(e.price || 0);
    byCurrency[c].count++;
  });
  if (offerPurchases.length > 0) byCurrency['FREE'] = { total: 0, count: offerPurchases.length };
  var currKeys = Object.keys(byCurrency).sort(function(a, b) { return byCurrency[b].total - byCurrency[a].total; });
  var revHtml = '';
  currKeys.forEach(function(c) {
    var d = byCurrency[c];
    var displayVal = c === 'FREE' ? d.count + ' codes' : d.total.toFixed(2) + ' ' + c;
    var usdLabel = (c === 'FREE' || c === 'USD') ? '' : ' (~$' + (d.total / (fxRates[c] || 1)).toFixed(2) + ')';
    revHtml += '<div class="stat-row">'
      + '<span style="font-size:13px;color:#888;">' + (c === 'FREE' ? 'Offer codes' : c) + ' <span style="color:#555;">(' + d.count + ')</span></span>'
      + '<span style="font-size:13px;font-weight:500;color:' + (c === 'FREE' ? '#C8A45C' : '#4ade80') + ';">' + displayVal + usdLabel + '</span></div>';
  });
  document.getElementById('revenueByCurrency').innerHTML = revHtml || '<div class="empty">No revenue yet</div>';

  var totalPurch = purchases.length || 1;
  var srcHtml = makeBar('Paid', paidPurchases.length, totalPurch, '#4ade80');
  srcHtml += makeBar('Code', offerPurchases.length, totalPurch, '#C8A45C');
  document.getElementById('sourceBreakdown').innerHTML = purchases.length > 0 ? srcHtml : '<div class="empty">No purchases yet</div>';

  var countries = {};
  events.forEach(function(e) { var l = (e.locale || '??').toUpperCase(); countries[l] = (countries[l] || 0) + 1; });
  var sortedC = Object.entries(countries).sort(function(a, b) { return b[1] - a[1]; }).slice(0, 8);
  var maxC = sortedC.length > 0 ? sortedC[0][1] : 1;
  document.getElementById('countryBars').innerHTML = sortedC.length > 0
    ? sortedC.map(function(c) { return makeBar(c[0], c[1], maxC, '#60a5fa'); }).join('')
    : '<div class="empty">No data yet</div>';

  var devices = {};
  events.forEach(function(e) { var d = e.device || '??'; devices[d] = (devices[d] || 0) + 1; });
  var sortedD = Object.entries(devices).sort(function(a, b) { return b[1] - a[1]; }).slice(0, 6);
  var maxD = sortedD.length > 0 ? sortedD[0][1] : 1;
  document.getElementById('deviceBars').innerHTML = sortedD.length > 0
    ? sortedD.map(function(d) { return makeWideBar(d[0], d[1], maxD, '#a78bfa'); }).join('')
    : '<div class="empty">No data yet</div>';

  var recent = events.slice(0, 30);
  document.getElementById('emptyState').style.display = recent.length === 0 ? 'block' : 'none';
  document.getElementById('eventsTable').innerHTML = recent.map(function(e) {
    var dt = new Date(e.created_at);
    var time = dt.toLocaleDateString('tr-TR', { month: 'short', day: 'numeric' }) + ' ' + dt.toLocaleTimeString('tr-TR', { hour: '2-digit', minute: '2-digit' });
    var badge = e.event === 'download' ? '<span class="badge badge-dl">download</span>'
      : e.source === 'offerCode' ? '<span class="badge badge-offer">offer code</span>'
      : '<span class="badge badge-iap">purchase</span>';
    var detail = '';
    if (e.event === 'purchase' && e.price) {
      var usd = toUSD(e.price, e.currency);
      detail = e.price + ' ' + (e.currency || 'USD');
      if (e.currency && e.currency !== 'USD') detail += ' ($' + usd.toFixed(2) + ')';
    } else if (e.locale) {
      detail = (e.locale).toUpperCase();
    }
    var appLabel = e.app === 'yula' ? '<span style="font-size:9px;color:#60a5fa;margin-left:4px;">Y</span>' : '';
    return '<tr><td style="white-space:nowrap;font-size:11px;color:#666;">' + time + '</td><td>' + badge + appLabel + '</td><td style="font-size:12px;color:#888;">' + detail + '</td><td id="del-' + e.id + '"><button class="btn-del" onclick="showDeleteConfirm(' + e.id + ')">✕</button></td></tr>';
  }).join('');
}

function getMonthlyRevenue() {
  var now = new Date();
  var monthStart = new Date(now.getFullYear(), now.getMonth(), 1).toISOString().slice(0, 7);
  var monthEvents = allEvents.filter(function(e) {
    return e.event === 'purchase' && e.source !== 'offerCode' && e.created_at && e.created_at.startsWith(monthStart);
  });
  var total = 0;
  monthEvents.forEach(function(e) { total += toUSD(e.price, e.currency); });
  return Math.round(total * 100) / 100;
}

function getGoal() {
  return parseFloat(localStorage.getItem('revenueGoal') || '50');
}

function renderGoal() {
  var goal = getGoal();
  var current = getMonthlyRevenue();
  var pct = goal > 0 ? Math.min(Math.round((current / goal) * 100), 100) : 0;
  var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  var monthName = months[new Date().getMonth()] + ' ' + new Date().getFullYear();
  document.getElementById('goalMonth').textContent = monthName + ' Goal';

  var barColor = pct >= 100 ? '#4ade80' : pct >= 50 ? '#C8A45C' : '#60a5fa';
  var statusText = '';
  var statusColor = '#888';

  if (pct >= 100) {
    statusText = 'Goal reached!';
    statusColor = '#4ade80';
  } else if (pct >= 75) {
    statusText = 'Almost there!';
    statusColor = '#C8A45C';
  } else if (pct >= 50) {
    statusText = 'Halfway!';
    statusColor = '#C8A45C';
  } else if (current > 0) {
    var remaining = goal - current;
    statusText = '$' + remaining.toFixed(2) + ' to go';
  } else {
    statusText = 'Waiting for first sale';
  }

  document.getElementById('goalContent').innerHTML =
    '<div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:8px;">'
    + '<span style="font-size:24px;font-weight:600;color:' + barColor + ';">$' + current.toFixed(2) + '</span>'
    + '<span style="font-size:14px;color:#555;">/ $' + goal.toFixed(0) + '</span>'
    + '</div>'
    + '<div style="height:8px;background:#111;border-radius:4px;overflow:hidden;margin-bottom:6px;">'
    + '<div style="height:100%;width:' + pct + '%;background:' + barColor + ';border-radius:4px;transition:width 0.5s;"></div>'
    + '</div>'
    + '<div style="display:flex;justify-content:space-between;">'
    + '<span style="font-size:11px;color:' + statusColor + ';">' + statusText + '</span>'
    + '<span style="font-size:11px;color:#555;">' + pct + '%</span>'
    + '</div>';

  // Celebrate when goal first reached
  var goalKey = 'goalCelebrated_' + new Date().toISOString().slice(0, 7);
  if (pct >= 100 && !localStorage.getItem(goalKey)) {
    localStorage.setItem(goalKey, 'true');
    fireworks();
    fireworks();
    confetti();
    showToast('Monthly goal reached!', 'iap');
  }
}

function editGoal() {
  document.getElementById('goalInput').value = getGoal();
  document.getElementById('goalContent').style.display = 'none';
  document.getElementById('goalEditBtn').style.display = 'none';
  document.getElementById('goalEditor').style.display = 'block';
}

function saveGoal() {
  var val = parseFloat(document.getElementById('goalInput').value);
  if (val > 0) {
    localStorage.setItem('revenueGoal', val.toString());
    // Reset celebration if goal changed
    var goalKey = 'goalCelebrated_' + new Date().toISOString().slice(0, 7);
    localStorage.removeItem(goalKey);
  }
  cancelGoalEdit();
  renderGoal();
}

function cancelGoalEdit() {
  document.getElementById('goalContent').style.display = 'block';
  document.getElementById('goalEditBtn').style.display = 'inline-block';
  document.getElementById('goalEditor').style.display = 'none';
}

function exportData() {
  var events = getFiltered();
  var downloads = events.filter(function(e) { return e.event === 'download'; });
  var purchases = events.filter(function(e) { return e.event === 'purchase'; });
  var paidPurchases = purchases.filter(function(e) { return e.source !== 'offerCode'; });
  var offerPurchases = purchases.filter(function(e) { return e.source === 'offerCode'; });

  var revenueUSD = 0;
  paidPurchases.forEach(function(e) { revenueUSD += toUSD(e.price, e.currency); });

  var countries = {};
  events.forEach(function(e) { var l = (e.locale || '??').toUpperCase(); countries[l] = (countries[l] || 0) + 1; });

  var devices = {};
  events.forEach(function(e) { var d = e.device || '??'; devices[d] = (devices[d] || 0) + 1; });

  var byCurrency = {};
  paidPurchases.forEach(function(e) {
    var c = e.currency || 'USD';
    if (!byCurrency[c]) byCurrency[c] = { total: 0, count: 0 };
    byCurrency[c].total += parseFloat(e.price || 0);
    byCurrency[c].count++;
  });

  var report = {
    exported: new Date().toISOString(),
    filter: { app: currentApp, time: currentTime },
    monthlyGoal: { target: getGoal(), current: getMonthlyRevenue(), month: new Date().toISOString().slice(0, 7) },
    summary: {
      downloads: downloads.length,
      purchases: purchases.length,
      paid: paidPurchases.length,
      offerCodes: offerPurchases.length,
      revenueUSD: Math.round(revenueUSD * 100) / 100,
      proceedsUSD: Math.round(revenueUSD * 0.85 * 100) / 100,
      conversion: downloads.length > 0 ? Math.round((purchases.length / downloads.length) * 1000) / 10 + '%' : '0%',
      arpu: downloads.length > 0 ? '$' + (Math.round(revenueUSD / downloads.length * 100) / 100) : '$0'
    },
    countries: countries,
    devices: devices,
    revenueByCurrency: byCurrency,
    recentEvents: events.slice(0, 20).map(function(e) {
      return {
        time: e.created_at,
        app: e.app,
        event: e.event,
        source: e.source || null,
        price: e.price || null,
        currency: e.currency || null,
        locale: e.locale,
        device: e.device
      };
    })
  };

  var text = JSON.stringify(report, null, 2);
  navigator.clipboard.writeText(text).then(function() {
    showToast('Copied to clipboard!', 'dl');
  }).catch(function() {
    var ta = document.createElement('textarea');
    ta.value = text;
    ta.style.position = 'fixed';
    ta.style.left = '-9999px';
    document.body.appendChild(ta);
    ta.select();
    document.execCommand('copy');
    document.body.removeChild(ta);
    showToast('Copied to clipboard!', 'dl');
  });
}

setInterval(function() { if (SECRET_KEY) loadData(); }, 60000);
setInterval(function() { loadFxRates(); }, 3600000);
init();
</script>
